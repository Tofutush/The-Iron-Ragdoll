---
layout: article.liquid
parent: Stories
---
<style>
	#prev-next {
		display: flex;
		gap: 2em;
		flex-wrap: wrap;

		&>* {
			min-width: 200px;
			flex: 1;
		}
	}
</style>
<dl>
	<dt>Main Cast</dt>
	<dd class="tags">
		{% for ch in chs %}
			{% include 'chButton', ch: ch %}
		{% endfor %}
	</dd>
	<dt>Time period</dt>
	<dd>{{ time }}</dd>
	<dt>Complete</dt>
	<dd>{% if complete %}{% lucide 'check' %}{% else %}{% lucide 'x' %}{% endif %}</dd>
	{% if myTags %}
		<dt>Tags</dt>
		<dd>
			{% assign sortedTags = myTags | sort %}{% for tag in sortedTags %}{% if forloop.index != 1 %}, {% endif %}<a href="/stories/tag/{{ tag | slug }}/">{{ tag }}</a>{% endfor %}
		</dd>
	{% endif %}
</dl>

{% if comic or fic %}
	<div class="box-nav solid">
		{% if comic %}
			<a href="1/">Read the comic!</a>
		{% endif %}
		{% if fic %}
			<a href="chapter-1/">Read the fic!</a>
		{% endif %}
	</div>
{% endif %}

{{ content }}

{% assign next = collections.stories | getNextStories: title %}
{% if prev or next.size != 0 %}
	<hr/>
	<section id="prev-next" data-pagefind-ignore>
		{% if prev %}
			<div class="callout" open>
      			<div class="callout-title">
					<div class="callout-title-icon">{% lucide 'step-back' 24 %}</div>
					<div class="callout-title-inner">Previous</div>
				</div>
				<div class="callout-content">
					<ul class="smaller-text">
						{% for s in prev %}
							<li><a href="{{ s | getUrlFromLink }}">{{ s | getNameFromLink }}</a></li>
						{% endfor %}
					</ul>
				</div>
			</div>
		{% endif %}
		{% if next.size != 0 %}
			<div class="callout" open>
      			<div class="callout-title">
					<div class="callout-title-icon">{% lucide 'step-forward' 24 %}</div>
					<div class="callout-title-inner">Next</div>
				</div>
				<div class="callout-content">
					<ul class="smaller-text">
						{% for s in next %}
							<li><a href="{{ s.url }}">{{ s.data.title }}</a></li>
						{% endfor %}
					</ul>
				</div>
			</div>
		{% endif %}
	</section>
{% endif %}
