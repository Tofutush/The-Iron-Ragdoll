---
layout: gallery.liquid
title: Character Art Progress
desc: See the progress on character art.
widepage: true
parent: Gallery
eleventyNavigation:
  order: 10
---
<style>
	.progress-bar {
		width: 100%;
		height: 2em;
		border-radius: 999px;
		background-color: var(--box);
	}
</style>
<p>My progress on the "Mandatory Character Art" (MCA) task I gave myself!</p>

<div class="table-responsive">
	<table>
		<thead>
			<tr>
				<th>Name</th>
				<th>Soul</th>
				<th>Thumb</th>
				<th>Profile</th>
				<th>Fullbody</th>
				<th>Pagedoll</th>
				<th>Reference</th>
				<th>Missing</th>
			</tr>
		</thead>
		<tbody>
			{% assign total = 0 %}
			{% for ch in characters %}
				{% assign filteredGallery = gallery | filterGallery: ch.name %}
				{% assign soul = filteredGallery | filterGalleryByKind: 'soul' %}
				{% assign thumb = filteredGallery | filterGalleryByKind: 'thumb' %}
				{% assign profile = filteredGallery | filterGalleryByKind: 'profile' %}
				{% assign fullbody = filteredGallery | filterGalleryByKind: 'fullbody' %}
				{% assign pagedoll = filteredGallery | filterGalleryByKind: 'pagedoll' %}
				{% assign ref = filteredGallery | filterGalleryByKind: 'ref' %}
				{% if soul.length == 0 or thumb.length == 0 or profile.length == 0 or fullbody.length == 0 or pagedoll.length == 0 or ref.length == 0 %}
					{% assign prevTotal = total %}
					<tr>
						<td><a href="/characters/{{ ch.name | lowerCase }}/">{{ ch.name }}</a></th>
						<td>{% if soul.length == 0 %}Soul{% else %}{% assign total = total | plus: 1 %}{% endif %}</td>
						<td>{% if thumb.length == 0 %}Thumb{% else %}{% assign total = total | plus: 1 %}{% endif %}</td>
						<td>{% if profile.length == 0 %}Profile{% else %}{% assign total = total | plus: 1 %}{% endif %}</td>
						<td>{% if fullbody.length == 0 %}Fullbody{% else %}{% assign total = total | plus: 1 %}{% endif %}</td>
						<td>{% if pagedoll.length == 0 %}Pagedoll{% else %}{% assign total = total | plus: 1 %}{% endif %}</td>
						<td>{% if ref.length == 0 %}Reference{% else %}{% assign total = total | plus: 1 %}{% endif %}</td>
						<td>{{ 6 | minus: total | plus: prevTotal }}</td>
					</tr>
				{% else %}
					{% assign total = total | plus: 6 %}
				{% endif %}
			{% endfor %}
		</tbody>
	</table>
</div>
<script src="/js/sort.js"></script>
<script>
	let sort = new SortTable(document.querySelector('table'));
	sort.addSort({
		colName: 'Soul',
		keyFunc: td => td.innerText,
		sortFunc: SortTable.sortFuncString
	});
	sort.addSort({
		colName: 'Thumb',
		keyFunc: td => td.innerText,
		sortFunc: SortTable.sortFuncString
	});
	sort.addSort({
		colName: 'Profile',
		keyFunc: td => td.innerText,
		sortFunc: SortTable.sortFuncString
	});
	sort.addSort({
		colName: 'Fullbody',
		keyFunc: td => td.innerText,
		sortFunc: SortTable.sortFuncString
	});
	sort.addSort({
		colName: 'Pagedoll',
		keyFunc: td => td.innerText,
		sortFunc: SortTable.sortFuncString
	});
	sort.addSort({
		colName: 'Reference',
		keyFunc: td => td.innerText,
		sortFunc: SortTable.sortFuncString
	});
	sort.addSort({
		colName: 'Missing',
		keyFunc: td => parseInt(td.innerText),
		sortFunc: SortTable.sortFuncNumber
	});
</script>
<p>Completed: {{ total }} out of {{ characters.size | times: 6 }} ({{ total | divided_by: characters.size | divided_by: 6 | times: 100 | round: 2 }}%)!</p>
<div class="progress-bar" style="background:linear-gradient(to right, var(--c) {{ total | divided_by: characters.size | divided_by: 6 | times: 100 }}%, var(--box) {{ total | divided_by: characters.size | divided_by: 6 | times: 100 }}%"></div>
