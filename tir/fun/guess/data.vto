---
permalink: "fun/guess/data.js"
---
{{ set data = characters |> getGuessData: relationships }}
const data = {{ data |> JSON.stringify }};

const imgs = {
    {{ for ch of data.ch }}{{ include 'imageUrl.vto' 'gallery/' `${ch.toLowerCase()} profile.png` 200 `${ch.toLowerCase()} thumb.png` |> htmlBaseUrl}}",{{ /for }}
};
