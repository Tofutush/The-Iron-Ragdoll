---
permalink: "fun/guess/data.js"
---
{{ set data = characters |> getGuessData(relationships) }}
const data = {{ data |> JSON.stringify }};

const imgs = {
    {{ for ch of data.ch }}{{ include 'imageUrl.vto' {path: 'gallery/', name: `${ch.toLowerCase()} profile.png`, size: 200, fallback: `${ch.toLowerCase()} thumb.png`} |> htmlBaseUrl}}",{{ /for }}
};
