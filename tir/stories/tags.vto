---
layout: storyLayout.vto
pagination:
  data: collections.storyTags
  size: 1
  alias: tag
  addAllPagesToCollections: true
permalink: "stories/tag/{{ tag |> slug }}/"
eleventyComputed:
  title: "{{ tag }} Stories"
  tag: "{{ tag }}"
  eleventyNavigation:
    key: "{{ tag }} Stories"
    title: "{{ tag }}"
    parent: Story Tags
---
{{ set filteredStories = collections.stories |> filterStoriesByTag(tag) }}
{{ include 'storylist.vto' {stories: filteredStories} }}
